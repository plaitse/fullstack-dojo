{
  "name": "@fullstack-dojo/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "test": "jest",
    "test:integration": "DATABASE_URL=postgresql://dojo:dojo@localhost:5433/fullstack_dojo_test jest --config jest.integration.config.js --runInBand",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "prisma:generate": "prisma generate --config ./prisma/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config ./prisma/prisma.config.ts",
    "prisma:studio": "prisma studio --config ./prisma/prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "effect": "^3.14.0",
    "eventemitter2": "^6.4.9",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.8.0"
  }
}
